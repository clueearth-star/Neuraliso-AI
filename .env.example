# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=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

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# Clerk Authentication Publishable Key (exposed to the client)
# Note: For Vite apps, use VITE_CLERK_PUBLISHABLE_KEY. For Next.js apps, use NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YWRlcXVhdGUtaG91bmQtODkuY2xlcmsuYWNjb3VudHMuZGV2JA
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YWRlcXVhdGUtaG91bmQtODkuY2xlcmsuYWNjb3VudHMuZGV2JA

# Clerk Secret Key (kept strictly on the backend/server-side code for secure requests)
CLERK_SECRET_KEY=sk_test_HV5VKTq5BMyQ0mpDdsHTxGtt1wbhV7EIwBisaB34tg

# NVIDIA API Key (Optional, for high-performance NVIDIA NIM inference)
NVIDIA_API_KEY=

# ElevenLabs API Key: Used to generate high-fidelity vocalizations for Aura the Mascot.
# If left blank, Aura gracefully falls back to native high-quality client-side Web SpeechSynthesis.
ELEVENLABS_API_KEY=

# Reviews & Testimonials Background SMTP Email Notification Config
# (Leave REVIEWS_NOTIFICATION_EMAIL blank to securely fallback to the decrypted administrator default fallback)
REVIEWS_NOTIFICATION_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_email_address
SMTP_PASS=your_smtp_app_password

# Google Analytics Measurement ID (exposed to client)
# If left blank, it defaults to G-SERENEAI99 for testing sandbox purposes
VITE_GA_MEASUREMENT_ID=

# Auth0 Authentication Config (exposed to client)
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_CALLBACK_URL=
VITE_AUTH0_LOGOUT_URL=

# Optional Authentication overrides (will fallback to firebase-applet-config.json if not provided)
VITE_FIREBASE_API_KEY=

# Cryptographic Master Key for AES-256-GCM
# Used to encrypt and decrypt sensitive application credentials at runtime (e.g. database credentials, API keys).
# Run "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"" to generate a secure random key.
MASTER_ENCRYPTION_KEY=

